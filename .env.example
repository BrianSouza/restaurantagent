# =============================================================================
#  Kisseki — Agente Conversacional  |  Configuração RAG
#  Copie este arquivo para .env e preencha APENAS o que for usar.
#  NUNCA commite o arquivo .env — ele já está no .gitignore.
# =============================================================================

# ── Provedor de LLM ────────────────────────────────────────────────────────────
# Opções: openai | anthropic | google | ollama
LLM_PROVIDER=openai

# Modelo específico (opcional — se vazio, usa o padrão do provedor)
# Padrões: openai→gpt-4o-mini | anthropic→claude-3-5-haiku-20241022
#          google→gemini-1.5-flash | ollama→llama3.2
# LLM_MODEL=

# ── Provedor de Embeddings ─────────────────────────────────────────────────────
# Opções: openai | google | ollama | huggingface
# Nota: Anthropic NÃO possui API de embeddings — use outro provedor.
EMBEDDING_PROVIDER=openai

# Modelo específico (opcional — se vazio, usa o padrão do provedor)
# Padrões: openai→text-embedding-3-small | google→models/text-embedding-004
#          ollama→nomic-embed-text | huggingface→sentence-transformers/all-MiniLM-L6-v2
# EMBEDDING_MODEL=

# ── Chaves de API ──────────────────────────────────────────────────────────────
# Preencha APENAS a(s) chave(s) do(s) provedor(es) que você selecionou acima.

# OpenAI  (necessária se LLM_PROVIDER=openai ou EMBEDDING_PROVIDER=openai)
# OPENAI_API_KEY=sk-...

# Anthropic  (necessária se LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini  (necessária se LLM_PROVIDER=google ou EMBEDDING_PROVIDER=google)
# GOOGLE_API_KEY=AIza...

# ── Ollama — Execução 100% Local ───────────────────────────────────────────────
# Não requer chave de API. Instale o Ollama em https://ollama.com e execute:
#   ollama pull llama3.2          # para LLM
#   ollama pull nomic-embed-text  # para embeddings
#
# URL do servidor Ollama local (padrão: http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434

# ── HuggingFace — Embeddings Locais ───────────────────────────────────────────
# Não requer chave de API. O modelo é baixado na primeira execução.
# Instale: pip install langchain-huggingface sentence-transformers
#
# Modelo (padrão: sentence-transformers/all-MiniLM-L6-v2)
# HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── ChromaDB ──────────────────────────────────────────────────────────────────
# Diretório local para persistir o índice vetorial (padrão: ./chroma_db)
# CHROMA_PERSIST_DIR=./chroma_db

# Nome da coleção dentro do ChromaDB (padrão: cardapio_kisseki)
# CHROMA_COLLECTION=cardapio_kisseki

# ── Retrieval ─────────────────────────────────────────────────────────────────
# Número de documentos retornados por consulta (padrão: 5)
# RETRIEVER_K=5

# Estratégia de busca: mmr (diversidade) | similarity (máx. relevância)
# RETRIEVER_SEARCH_TYPE=mmr

# =============================================================================
#  Exemplos de combinações comuns
# =============================================================================
#
#  1) Apenas OpenAI (cloud):
#     LLM_PROVIDER=openai
#     EMBEDDING_PROVIDER=openai
#     OPENAI_API_KEY=sk-...
#
#  2) Anthropic + OpenAI Embeddings (Anthropic não tem embeddings):
#     LLM_PROVIDER=anthropic
#     EMBEDDING_PROVIDER=openai
#     ANTHROPIC_API_KEY=sk-ant-...
#     OPENAI_API_KEY=sk-...
#
#  3) Google Gemini (tudo Google):
#     LLM_PROVIDER=google
#     EMBEDDING_PROVIDER=google
#     GOOGLE_API_KEY=AIza...
#
#  4) 100% local com Ollama:
#     LLM_PROVIDER=ollama
#     EMBEDDING_PROVIDER=ollama
#     OLLAMA_BASE_URL=http://localhost:11434
#     LLM_MODEL=llama3.2
#     EMBEDDING_MODEL=nomic-embed-text
#
#  5) 100% local com HuggingFace embeddings + Ollama LLM:
#     LLM_PROVIDER=ollama
#     EMBEDDING_PROVIDER=huggingface
#     HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# =============================================================================
